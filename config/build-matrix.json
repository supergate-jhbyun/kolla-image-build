{
  "schema_version": 1,
  "owner": "supergate-jhbyun",
  "repository": "kolla-image-build",
  "registry": "ghcr.io",
  "release": "2025.1",
  "profiles": [
    "core"
  ],
  "distros": [
    {
      "name": "rocky",
